DATABASE_URL=postgresql+asyncpg://cixiohub:cixiohub@localhost:5432/cixiohub
TEST_EMAIL=test@example.com
TEST_PASSWORD=your_test_password
TEST_NAME=Test User
TEST_PHONE=0000000000

# Application
APP_NAME="CixioHub API"
DEBUG=False

# Database


# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=your_secret_key_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_EMBED_MODEL=nomic-embed-text

# AI Service
AI_SERVICE_URL=http://localhost:8003

# ChromaDB
CHROMA_HOST=localhost
CHROMA_PORT=8002

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# AWS / S3 / MinIO
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
AWS_ENDPOINT_URL=
S3_BUCKET=cixiohub-uploads
S3_BUCKET_NAME=cixiohub-uploads

# SMTP / Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM_EMAIL=noreply@hub.cixio.dev

# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret

# File upload
MAX_UPLOAD_SIZE_MB=50
