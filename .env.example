# CixioHub Backend — Local Dev Environment
DEBUG=true

# Database
DATABASE_URL=

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT — safe default for local dev only
SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Ollama (used by AI service directly; kept for reference)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
OLLAMA_EMBED_MODEL=nomic-embed-text

# AI Service (LLM + RAG + document extraction)
AI_SERVICE_URL=http://localhost:8003

# RabbitMQ
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# MinIO (S3-compatible local storage)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=http://localhost:9000
AWS_REGION=
S3_BUCKET=

# Email (MailHog — catches all email locally)
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
